# 发布密码(前端登录用,只你一个人知道)
BLOG_PASSWORD=change-me

# JWT 签发密钥(随机长串,可用 `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`)
JWT_SECRET=change-me-to-a-long-random-string

# 服务器上仓库 clone 的绝对路径
REPO_PATH=/srv/blog-repo

# 监听端口(nginx 反代到这里)
PORT=3001

# git commit 用的身份
GIT_USER_NAME=gaga-blog-bot
GIT_USER_EMAIL=bot@example.com

# 远端分支名(默认 main)
GIT_BRANCH=main

# token 有效期(小时)
TOKEN_TTL_HOURS=12
